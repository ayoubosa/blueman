# Copy to .env and fill in. Never commit .env.
BLUEMAN_ENV=development
BLUEMAN_SECRET_KEY=change-me-to-a-long-random-string
BLUEMAN_DATABASE_URL=sqlite:///./blueman.db
BLUEMAN_ANTHROPIC_API_KEY=sk-ant-...
BLUEMAN_ANTHROPIC_MODEL=claude-sonnet-5
BLUEMAN_QDRANT_URL=http://localhost:6333
BLUEMAN_QDRANT_API_KEY=
BLUEMAN_CORS_ORIGINS=["http://localhost:5173","https://blueman-five.vercel.app"]
BLUEMAN_ACCESS_TOKEN_EXPIRE_MINUTES=1440
